    "build": "tsc",
    "postbuild": "cross-env-shell echo \"Build complete\"",
    "build:watch": "tsc --watch",
    "type-check": "tsc --noEmit",
    "test": "NODE_ENV=test jest --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "migrate": "node -r ts-node/register/transpile-only scripts/migrate.ts",
    "seed": "node -r ts-node/register/transpile-only scripts/seed.ts"
