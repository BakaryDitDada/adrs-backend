{
  "watch": ["src"],
  "ext": "ts,js,json",
  "ignore": [
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "node_modules",
    "dist",
    "coverage"
  ],
  "exec": "node --loader ts-node/esm src/server.ts",
  "execMap": {
    "ts": "node --loader ts-node/esm"
  },
  "env": {
    "NODE_ENV": "development",
    "TS_NODE_PROJECT": "./tsconfig.json"
  },
  "events": {
    "restart": "echo '🔄 Server restarted due to changes...'"
  }
}